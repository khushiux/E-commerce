        print("5.  View Recommendations")
        print("6.  Checkout")
        print("7.  Order History")
        print("8.  Customer Profile")
        print("9.  Exit")
        print("="*70)
    
    def browse_products(self):
        """Browse products with filtering"""
        categories = self.store.get_categories()
        
        print("\n📂 Categories:")
        for i, category in enumerate(categories, 1):
            count = len(self.store.get_products_by_category(category))
            print(f"  {i}. {category} ({count} products)")
        print(f"  {len(categories) + 1}. All Products")
        
        try:
            choice = int(input("\nSelect category: "))
            
            if choice == len(categories) + 1:
                products = self.store.get_all_products()
            elif 1 <= choice <= len(categories):
                products = self.store.get_products_by_category(categories[choice - 1])
            else:
                print("Invalid selection")
                return
            
            self.store.display_products(products)
            self._add_to_cart_prompt()
        except ValueError:
            print("Invalid input")
    
    def search_products(self):
        """Search for products"""
        keyword = input("Enter search keyword: ").strip()
        if not keyword:
            print("Invalid input")
            return
        
        results = self.store.search_products(keyword)
        
        if results:
            print(f"\n✅ Found {len(results)} product(s)")
            self.store.display_products(results)
            self._add_to_cart_prompt()
        else:
            print("No products found")
    
    def _add_to_cart_prompt(self):
        """Prompt to add products to cart"""
        if not self.cart:
            print("Please login first")
            return
        
        while True:
            add = input("\nAdd to cart? (yes/no): ").strip().lower()
            
            if add == 'yes':
                product_id = input("Enter Product ID: ").strip()
                product = self.store.get_product(product_id)
                
                if not product:
                    print("❌ Product not found")
                    continue
                
                try:
                    qty = int(input(f"Quantity (max {product.stock}): "))
                    if self.cart.add_item(product, qty):
                        print(f"✅ Added {qty}x {product.name}")
                    else:
                        print("❌ Failed to add item")
                except ValueError:
                    print("❌ Invalid quantity")
            
            elif add == 'no':
                break
            else:
                print("Invalid choice")
    
    def view_cart(self):
        """View shopping cart"""
        if not self.cart or self.cart.is_empty():
            print("\n📭 Your cart is empty")
            return
        
        self.cart.display_cart()
        
        print("\n📦 Cart Options:")
        print("1. Update Item Quantity")
        print("2. Remove Item")
        print("3. Clear Cart")
        print("4. View Recommendations")
        print("5. Back")
        
        choice = input("Select option (1-5): ").strip()
        
        if choice == '1':
            self._update_item()
        elif choice == '2':
            self._remove_item()
        elif choice == '3':
            if input("Clear cart? (yes/no): ").lower() == 'yes':
                self.cart.clear_cart()
                print("✅ Cart cleared")
        elif choice == '4':
            self.show_recommendations()
    
    def _update_item(self):
        """Update item quantity"""
        product_id = input("Enter Product ID: ").strip()
        try:
            qty = int(input("New quantity: "))
            if self.cart.update_item_quantity(product_id, qty):
                print("✅ Updated")
            else:
                print("❌ Failed")
        except ValueError:
            print("Invalid input")
    
    def _remove_item(self):
        """Remove item from cart"""
        product_id = input("Enter Product ID: ").strip()
        if self.cart.remove_item(product_id):
            print("✅ Removed")
        else:
            print("❌ Not found")
    
    def apply_discount_code(self):
        """Apply discount code to cart"""
        if not self.cart or self.cart.is_empty():
            print("Cart is empty")
            return
        
        code = input("Enter discount code: ").strip().upper()
        discount = self.store.get_discount(code)
        
        if not discount:
            print("❌ Discount code not found")
            return
        
        success, msg = self.cart.apply_discount(discount)
        if success:
            print(f"✅ {msg}")
            print(f"You save: ${self.cart.get_total_discount():.2f}")
        else:
            print(f"❌ {msg}")
    
    def show_recommendations(self):
        """Show product recommendations"""
        recommendations = self.get_recommendations()
        
        if recommendations:
            print("\n💡 Recommended for you:")
            self.store.display_products(recommendations)
        else:
            print("No recommendations available")
    
    def checkout(self):
        """Process checkout"""
        if not self.cart or self.cart.is_empty():
            print("Your cart is empty")
            return
        
        print("\n" + "="*70)
        print("CHECKOUT".center(70))
        print("="*70)
        
        # Show order summary
        summary = self.cart.get_final_total()
        
        print(f"\nSubtotal:        ${summary['subtotal']:>15.2f}")
        print(f"Discount:       -${summary['discount']:>15.2f}")
        print(f"Tax (8%):        ${summary['tax']:>15.2f}")
        print(f"Shipping:        ${summary['shipping']:>15.2f}")
        print("-" * 50)
        print(f"TOTAL:           ${summary['total']:>15.2f}")
        print("=" * 50)
        
        # Process payment
        self._process_payment(summary)
    
    def _process_payment(self, summary: Dict[str, float]):
        """Process payment"""
        print("\n💳 Payment Methods:")
        print("1. Credit/Debit Card")
        print("2. PayPal")
        
        choice = input("Select method (1-2): ").strip()
        
        if choice == '1':
            self._process_card_payment(summary)
        elif choice == '2':
            self._process_paypal_payment(summary)
        else:
            print("Invalid selection")
    
    def _process_card_payment(self, summary: Dict[str, float]):
        """Process card payment"""
        try:
            print("\n💳 Enter Card Details:")
            name = input("Cardholder Name: ").strip()
            number = input("Card Number: ").strip()
            month = int(input("Expiry Month: "))
            year = int(input("Expiry Year: "))
            cvv = input("CVV: ").strip()
            
            card = CreditCard(name, number, month, year, cvv)
            success, msg, txn_id = card.process(summary['total'], f"ORD-{uuid.uuid4().hex[:8]}")
            
            if success:
                self._complete_order(summary, "Credit Card", txn_id)
            else:
                print(f"❌ {msg}")
        except ValueError:
            print("Invalid input")
    
    def _process_paypal_payment(self, summary: Dict[str, float]):
        """Process PayPal payment"""
        email = input("PayPal Email: ").strip()
        paypal = PayPalPayment(email)
        success, msg, txn_id = paypal.process(summary['total'], f"ORD-{uuid.uuid4().hex[:8]}")
        
        if success:
            self._complete_order(summary, "PayPal", txn_id)
        else:
            print(f"❌ {msg}")
    
    def _complete_order(self, summary: Dict[str, float], payment_method: str, txn_id: str):
        """Complete order"""
        order_id = f"ORD-{uuid.uuid4().hex[:8].upper()}"
        
        items = []
        for item in self.cart.get_cart_items():
            items.append({
                'product_id': item.product.product_id,
                'name': item.product.name,
                'quantity': item.quantity,
                'unit_price': item.product.price,
                'subtotal': item.get_subtotal()
            })
            item.product.reduce_stock(item.quantity)
        
        order = Order(
            order_id=order_id,
            customer_id=self.current_customer.customer_id,
            customer_name=self.current_customer.name,
            customer_email=self.current_customer.email,
            items=items,
            subtotal=summary['subtotal'],
            tax=summary['tax'],
            shipping=summary['shipping'],
            total=summary['total'],
            payment_method=payment_method,
            transaction_id=txn_id,
            status=OrderStatus.CONFIRMED
        )
        
        self.orders[order_id] = order
        
        # Update customer
        self.current_customer.orders.append(order_id)
        self.current_customer.add_points(summary['total'])
        
        print("\n" + "="*70)
        print("✅ ORDER CONFIRMED".center(70))
        print("="*70)
        print(f"Order ID: {order_id}")
        print(f"Total: ${summary['total']:.2f}")
        print(f"Points Earned: {int(summary['total'])}")
        print(f"New Tier: {self.current_customer.tier.value.upper()}")
        print("="*70)
        
        self.cart.clear_cart()
    
    def view_order_history(self):
        """View order history"""
        if not self.current_customer or not self.current_customer.orders:
            print("No orders found")
            return
        
        print("\n" + "="*70)
        print("ORDER HISTORY".center(70))
        print("="*70)
        
        for order_id in self.current_customer.orders:
            order = self.orders.get(order_id)
            if order:
                print(f"\nOrder ID: {order.order_id}")
                print(f"Date: {order.created_at.strftime('%Y-%m-%d %H:%M:%S')}")
                print(f"Total: ${order.total:.2f}")
                print(f"Status: {order.status.value}")
                print(f"Items: {len(order.items)}")
    
    def view_profile(self):
        """View customer profile"""
        if not self.current_customer:
            print("Not logged in")
            return
        
        print("\n" + "="*70)
        print("CUSTOMER PROFILE".center(70))
        print("="*70)
        print(f"ID: {self.current_customer.customer_id}")
        print(f"Name: {self.current_customer.name}")
        print(f"Email: {self.current_customer.email}")
        print(f"Tier: {self.current_customer.tier.value.upper()}")
        print(f"Loyalty Points: {self.current_customer.points:.0f}")
        print(f"Total Spent: ${self.current_customer.total_spent:.2f}")
        print(f"Orders: {len(self.current_customer.orders)}")
        print("="*70)
    
    def run(self):
        """Run application"""
        print("\n🛍️  Welcome to Advanced E-commerce Store!\n")
        
        # Customer login/registration
        name = input("Enter your name: ").strip()
        email = input("Enter your email: ").strip()
        self.create_customer(name, email)
        
        print(f"\n✅ Welcome, {self.current_customer.name}!")
        
        while True:
            self.display_main_menu()
            choice = input("Select option (1-9): ").strip()
            
            if choice == '1':
                self.browse_products()
            elif choice == '2':
                self.search_products()
            elif choice == '3':
                self.view_cart()
            elif choice == '4':
                self.apply_discount_code()
            elif choice == '5':
                self.show_recommendations()
            elif choice == '6':
                self.checkout()
            elif choice == '7':
                self.view_order_history()
            elif choice == '8':
                self.view_profile()
            elif choice == '9':
                print("\n👋 Thank you for shopping with us!")
                break
            else:
                print("Invalid selection")


