# ==================== STORE CLASS ====================
class Store:
    """Advanced store management"""
    
    def __init__(self, store_name: str, data_file: str = "store_data.json"):
        self.store_name = store_name
        self.products: Dict[str, Product] = {}
        self.categories: Dict[str, List[str]] = {}
        self.discounts: Dict[str, Discount] = {}
        self.data_file = data_file
        self.load_data()
    
    def add_product(self, product: Product) -> bool:
        """Add product to catalog"""
        if product.product_id in self.products:
            return False
        
        self.products[product.product_id] = product
        
        if product.category not in self.categories:
            self.categories[product.category] = []
        self.categories[product.category].append(product.product_id)
        
        self.save_data()
        return True
    
    def remove_product(self, product_id: str) -> bool:
        """Remove product"""
        if product_id not in self.products:
            return False
        
        product = self.products[product_id]
        del self.products[product_id]
        self.categories[product.category].remove(product_id)
        
        self.save_data()
        return True
    
    def get_product(self, product_id: str) -> Optional[Product]:
        """Get product by ID"""
        return self.products.get(product_id)
    
    def search_products(self, keyword: str, category: str = None) -> List[Product]:
        """Search products"""
        keyword = keyword.lower()
        results = []
        
        for product in self.products.values():
            if category and product.category != category:
                continue
            
            if (keyword in product.name.lower() or
                keyword in product.description.lower() or
                any(keyword in tag.lower() for tag in product.tags)):
                results.append(product)
        
        return results
    
    def get_products_by_category(self, category: str) -> List[Product]:
        """Get products by category"""
        if category not in self.categories:
            return []
        
        return [self.products[pid] for pid in self.categories[category]]
    
    def get_trending_products(self, limit: int = 5) -> List[Product]:
        """Get trending products based on reviews"""
        products = list(self.products.values())
        return sorted(products, key=lambda p: p.get_average_rating(), reverse=True)[:limit]
    
    def get_all_products(self) -> List[Product]:
        """Get all products"""
        return list(self.products.values())
    
    def get_categories(self) -> List[str]:
        """Get all categories"""
        return sorted(list(self.categories.keys()))
    
    def add_discount(self, discount: Discount) -> bool:
        """Add discount code"""
        if discount.code in self.discounts:
            return False
        
        self.discounts[discount.code] = discount
        self.save_data()
        return True
    
    def get_discount(self, code: str) -> Optional[Discount]:
        """Get discount by code"""
        return self.discounts.get(code)
    
    def save_data(self):
        """Save all data to file"""
        try:
            data = {
                'products': {pid: p.to_dict() for pid, p in self.products.items()},
                'discounts': {code: asdict(d) for code, d in self.discounts.items()}
            }
            with open(self.data_file, 'w') as f:
                json.dump(data, f, indent=4, default=str)
        except Exception as e:
            print(f"Error saving data: {e}")
    
    def load_data(self):
        """Load data from file"""
        if not os.path.exists(self.data_file):
            return
        
        try:
            with open(self.data_file, 'r') as f:
                data = json.load(f)
            # Reconstruction logic would go here
        except Exception as e:
            print(f"Error loading data: {e}")
    
    def display_products(self, products: Optional[List[Product]] = None):
        """Display products"""
        if products is None:
            products = self.get_all_products()
        
        if not products:
            print("No products available.")
            return
        
        print("\n" + "="*120)
        print(f"{'ID':<10} {'Name':<25} {'Description':<25} {'Price':>10} "
              f"{'Stock':>8} {'Rating':>8} {'Category':<15}")
        print("="*120)
        
        for product in products:
            rating = f"⭐{product.get_average_rating()}" if product.reviews else "N/A"
