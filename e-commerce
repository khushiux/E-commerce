        self.cart: Optional[ShoppingCart] = None
    
    def create_customer(self, name: str, email: str) -> Customer:
        """Create new customer"""
        customer_id = f"CUST-{uuid.uuid4().hex[:8].upper()}"
        customer = Customer(customer_id, name, email)
        self.customers[customer_id] = customer
        self.current_customer = customer
        self.cart = ShoppingCart(customer.tier)
        return customer
    
    def get_recommendations(self, limit: int = 5) -> List[Product]:
        """Get product recommendations"""
        if not self.cart or self.cart.is_empty():
            return self.store.get_trending_products(limit)
        
        # Get categories from items in cart
        categories = set()
        for item in self.cart.get_cart_items():
            categories.add(item.product.category)
        
        # Get related products
        recommendations = []
        for category in categories:
            products = self.store.get_products_by_category(category)
            recommendations.extend(products)
        
        # Remove items already in cart and return
        cart_ids = [item.product.product_id for item in self.cart.get_cart_items()]
        recommendations = [p for p in recommendations if p.product_id not in cart_ids]
        
        return recommendations[:limit]
    
