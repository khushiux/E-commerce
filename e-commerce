@dataclass
class Customer:
    """Customer with loyalty program"""
    customer_id: str
    name: str
    email: str
    tier: CustomerTier = CustomerTier.BRONZE
    points: float = 0.0
    total_spent: float = 0.0
    orders: List[str] = field(default_factory=list)
    created_at: datetime = field(default_factory=datetime.now)
    
    def add_points(self, amount: float):
        """Add loyalty points"""
        # 1 point per dollar spent
        points_earned = round(amount)
        self.points += points_earned
        
        # Update tier based on total spent
        self.total_spent += amount
        self._update_tier()
    
    def _update_tier(self):
        """Update customer tier based on spending"""
        if self.total_spent >= 10000:
            self.tier = CustomerTier.PLATINUM
        elif self.total_spent >= 5000:
            self.tier = CustomerTier.GOLD
        elif self.total_spent >= 2000:
            self.tier = CustomerTier.SILVER
        else:
            self.tier = CustomerTier.BRONZE
    
    def redeem_points(self, points: float) -> bool:
        """Redeem loyalty points"""
        if self.points >= points:
            self.points -= points
            return True
        return False
    
    def get_discount_rate(self) -> float:
        """Get discount rate based on tier"""
        rates = {
            CustomerTier.BRONZE: 0.0,
            CustomerTier.SILVER: 0.05,
            CustomerTier.GOLD: 0.10,
            CustomerTier.PLATINUM: 0.15
        }
        return rates.get(self.tier, 0.0)


